<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:backgroundTint="#F5F5F5"
    android:padding="24dp"
    > <TextView
    android:id="@+id/tvSheetCategory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Categoría"
    android:textColor="#FF9075"
    android:textSize="22sp"
    android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Reportado por:"
        android:textColor="#888888"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvSheetReporter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Nombre del usuario"
        android:textColor="#292626"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Descripción del reporte:"
        android:textColor="#888888"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvSheetDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Aquí va la descripción detallada..."
        android:textColor="#292626"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnCerrarSheet"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Cerrar"
        android:textColor="#FF9075"
        app:strokeColor="#FF9075"
        app:cornerRadius="8dp" />

</LinearLayout>